---
layout: none
---
[
{% assign all_items = site.products | concat: site.sellers %}
{% assign first = true %}
{% for item in all_items %}
  {% if item.title %}
    {% unless first %},{% endunless %}
    {
      "type": {{ item.collection | jsonify }},
      "title": {{ item.title | jsonify }},
      "price": {{ item.price | default: "" | jsonify }},
      "seller_name": {{ item.boutik_nom | default: item.vendeur | default: "" | jsonify }},
      "url": {{ item.url | absolute_url | jsonify }},
      "desc": {{ item.content | strip_html | truncate: 150 | jsonify }}
    }
    {% assign first = false %}
  {% endif %}
{% endfor %}
]
